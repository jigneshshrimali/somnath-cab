# ---- Database (booking persistence) ----
# ---- Booking persistence (required on Vercel/serverless — see lib/booking-store.ts) ----
# From your Supabase project: Settings -> API. Use the SERVICE ROLE key (not
# the anon/public key) since this is only ever read server-side. For local
# dev, leave blank to use the local data/bookings.json file fallback instead.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (booking persistence) ----
DATABASE_URL=

# ---- Email (transactional notifications) ----
RESEND_API_KEY=
EMAIL_FROM="Somnath Cab <bookings@somnathcab.in>"

# ---- SMS (booking confirmations / OTP) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Analytics ----
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# ---- Admin Dashboard ----
# Generate with: node scripts/hash-password.js "YourStrongPassword"
ADMIN_PASSWORD_HASH=
# Any long random string — used to sign admin session cookies
ADMIN_SESSION_SECRET=

# ---- Security ----
RATE_LIMIT_REDIS_URL=
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
